# ============================================================================
# 미국 주식 자동매매 시스템 — .env 템플릿 (US_Stock_Dev_Blueprint.md 4장 기준)
#
# 이 파일을 ".env"로 복사한 뒤 실제 값을 채운다. .env는 .gitignore에 이미 포함됨.
# 브로커·데이터소스는 아직 "결정 필요" 항목이라 두 가지 선택지를 모두 적어뒀다 —
# 실제로 고른 쪽만 채우고 나머지는 비워두거나 지워도 된다 (코드가 참조 안 함).
# ============================================================================

# ── ① 브로커 API — 선택 A: KIS 해외주식 (기존 국내 인프라 재사용) ────────────
# KIS 개발자센터(https://apiportal.koreainvestment.com)에서 "해외주식" 권한으로
# 앱키/시크릿 재발급 필요 (국내주식용 키와 tr_id 세트가 다름, 그대로 못 씀).
# 모의/실전은 반드시 분리 저장 (토큰 캐시도 파일 분리 — kis_client.py 참고).
KIS_MOCK=true

KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NO=
KIS_MOCK_ACCOUNT_PRODUCT_CD=01

KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NO=
KIS_REAL_ACCOUNT_PRODUCT_CD=01

# ── ① 브로커 API — 선택 B: Alpaca (미국 네이티브 브로커) ─────────────────────
# https://app.alpaca.markets 에서 발급. Paper(모의)/Live(실전) 키가 완전히 별개
# 시스템이라 KIS처럼 한 키로 스위치하는 게 아니라 애초에 발급 자체가 분리됨.
ALPACA_MODE=paper                 # paper=모의, live=실전
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# ── ② 시세(가격) 데이터 — 분봉 수집 가능 여부까지 확인 후 결정 ───────────────
# Alpaca를 브로커로 쓰면 Market Data도 같은 키로 해결되는 경우가 많음(플랜 확인).
# Polygon.io: 별도 유료 API, 분봉/틱 데이터 풍부.
POLYGON_API_KEY=

# Tiingo — yfinance가 못 찾는 상장폐지·개명 종목 보충용 (무료 티어: 시간당 50회,
# 하루 1000회, 월 500종목 — https://www.tiingo.com 이메일 가입으로 무료 발급)
TIINGO_API_KEY=

# yfinance는 API 키가 필요 없음 (무료, 일봉 위주 — 분봉 안정성은 별도 검증 필요).

# ── ③ 재무제표 데이터 — SEC EDGAR (API 키 불필요) ────────────────────────────
# https://www.sec.gov/os/webmaster-faq#developers
# 키는 없지만 요청 헤더에 "실명 + 연락처" User-Agent를 반드시 넣어야 함
# (형식 준수 안 하면 IP 차단당할 수 있음 — 예: "MyCompany contact@example.com").
SEC_EDGAR_USER_AGENT=

# ── ④ 유니버스(지수 구성종목) ────────────────────────────────────────────────
# S&P500 / 나스닥100은 위키피디아 표 스크래핑 방식이라 이미 코드에 구현되어
# 있음(data/index_constituents.py) — 이 섹션은 키가 필요 없어 항목 없음.
# 다만 "역사적" 편입/편출 이력(생존편향 방지용)은 위키 최신 표만으론 부족할 수
# 있어 유료 데이터소스로 갈지 별도 결정 필요 (블루프린트 4장 참고).

# ── ⑤ 매크로 지표 캐시 (VIX, 금리 등 — 국내 KR 전용 항목은 통화 결정에 따라 조정) ──
FRED_API_KEY=
# FRED(연준 경제데이터, https://fred.stlouisfed.org/docs/api/api_key.html)
# — us_10y(10년물 금리) 등 매크로 지표용. 키 무료 발급.

# ── ⑥ 환전/통화 (원화 계좌로 매매 시에만 필요 — 결정 전까지 비워둬도 됨) ──────
EXCHANGE_RATE_API_KEY=

# ── ⑦ 이메일 리포트 (국내와 동일하게 재사용) ─────────────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_TO=

# ── ⑧ 기타 ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
